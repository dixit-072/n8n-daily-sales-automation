    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet totalRevenue = 0;\nlet totalQuantity = 0;\n\nlet topProduct = \"\";\nlet highestRevenue = 0;\n\nconst salesData = [];\n\nfor (const item of items) {\n\n  const revenue = Number(item.json.revenue);\n  const quantity = Number(item.json.total_quantity);\n\n  totalRevenue += revenue;\n  totalQuantity += quantity;\n\n  if (revenue > highestRevenue) {\n    highestRevenue = revenue;\n    topProduct = item.json.product_name;\n  }\n\n  salesData.push(item.json);\n}\n\nreturn [\n{\njson:{\n    totalRevenue,\n    totalQuantity,\n    topProduct,\n    salesData\n}\n}\n];"
      },
