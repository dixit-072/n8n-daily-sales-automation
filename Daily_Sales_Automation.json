        "query": "SELECT\nproduct_name,\nSUM(quantity) total_quantity,\nSUM(total_amount) revenue\nFROM sales\nWHERE DATE(sale_date)=CURDATE()-INTERVAL 1 DAY\nGROUP BY product_name;",
